# Root
/*

!/.cargo/
!/.github/
!/crates/
!/deploy/
!/docs/
!/src/

!/.env.example
!/.gitattributes
!/.gitignore
!/Cargo.toml
!/Cargo.lock
!/README.md
!/clippy.toml
!/deny.toml

!/.cargo/**
!/.github/**
!/crates/**
!/deploy/**
!/docs/**
!/src/**

# Rust build artifacts
/target/
crates/tests/target/
**/*.rs.bk
*.pdb

# Tailwind CSS standalone CLI (downloaded locally, invoked by build.rs)
# See crates/client/build.rs — contributors download the binary to this path.
/crates/client/tailwindcss
/crates/client/tailwindcss.exe

# Generated by build.rs from tailwind.config.js + input.css; never commit.
/crates/client/src/assets/tailwind.css

# Python
*.pyc
__pycache__
*bundle*

# ZIP files
*.zip
*.exe
*.tgz
*.tar.gz
*.tgz

# Test output
/crates/tests/tests/ui/*.jpeg
playwright-report
test-results

# Download test
*.iso
*.aria2

# IDEs
.claude
.vscode
.idea/
*.swp
*.swo
*~

# Logs
*.log
nohup*

# Runtime data
pids
*.pid
*.seed
*.pid.lock


# Dependency directories
node_modules

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# Black-box test evidence artifacts (real API responses, not for version control)
evidence
.gstack
.gitnexus
