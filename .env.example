# ── Server ────────────────────────────────────────────────────────────────────
# Server listening port
PORT=3000
# Server listening host
HOST=127.0.0.1
# Public base URL used for OAuth redirects and link generation
BASE_URL=http://127.0.0.1:3000

# ── Secrets ───────────────────────────────────────────────────────────────────
# Master encryption key for upstream API keys (64 hex chars = 32 bytes).
# Auto-generated on first run if missing; must be stable across restarts.
# MASTER_KEY=<auto-generated>
# JWT signing secret. Must be changed in production.
# Default (debug builds): burncloud-default-secret-change-in-production
# JWT_SECRET=burncloud-default-secret-change-in-production
# Shared secret for internal API endpoints (X-Internal-Secret header). Optional.
# BURNCLOUD_INTERNAL_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Database connection string. Defaults to local SQLite if unset.
# For PostgreSQL: postgres://user:pass@host:5432/dbname
# BURNCLOUD_DATABASE_URL=sqlite:burncloud.db
# When using local SQLite, set to 0 to preserve data across restarts.
# Default: 1 (fresh DB on every startup)
# BURNCLOUD_FRESH_DB=1

# ── Billing ───────────────────────────────────────────────────────────────────
# Strict billing mode. When true (default), requests with unknown prices
# are rejected (400). Set to false or 0 to allow them with a warning.
# Default: true
# BILLING_STRICT_MODE=true

# ── Price Sync ────────────────────────────────────────────────────────────────
# Interval in seconds between background price syncs from the pricing repo.
# Default: 86400 (24 hours)
# PRICE_SYNC_INTERVAL_SECS=86400
# Set to any value to skip the initial price sync at startup (useful in tests).
# SKIP_INITIAL_PRICE_SYNC=1

# ── Scheduler ─────────────────────────────────────────────────────────────────
# JSON object defining scheduler policies per group. Falls back to
# all-groups-passthrough if unset or invalid.
# Example: {"vip":{"type":"combined","health_weight":0.4,"cost_weight":0.4,"rpm_weight":0.2},"default":{"type":"passthrough"}}
# SCHEDULER_POLICIES=

# ── CLI / Price Tool ─────────────────────────────────────────────────────────
# Server URL used by the `burncloud price` CLI subcommand.
# Default: http://127.0.0.1:3000
# BURNCLOUD_SERVER_URL=http://127.0.0.1:3000

# ── OAuth (optional, required for SSO) ───────────────────────────────────────
# Google OAuth 2.0 client ID (required for Google SSO)
# GOOGLE_CLIENT_ID=
# Google OAuth redirect URI (must match Google Cloud Console)
# GOOGLE_REDIRECT_URI=http://localhost:8080/console/api/auth/google/callback
# GitHub OAuth client ID (required for GitHub SSO)
# GITHUB_CLIENT_ID=
# GitHub OAuth redirect URI (must match GitHub OAuth App settings)
# GITHUB_REDIRECT_URI=http://localhost:8080/console/api/auth/github/callback

# ── Local Inference ──────────────────────────────────────────────────────────
# Path to llama-server binary. Falls back to ./bin/llama-server, ./llama-server,
# then system PATH if unset.
# BURNCLOUD_LLAMA_BIN=

# ── Installer ────────────────────────────────────────────────────────────────
# Custom npm registry mirror URL. Auto-detects China region if unset.
# NPM_MIRROR=

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=error
LOG_DIR=./logs
LOG_MAX_FILES=7

# ── Test / Development ────────────────────────────────────────────────────────
# Test OpenAI API
TEST_OPENAI_BASE_URL=https://api.openai.com
TEST_OPENAI_API_KEY=sk-1231234567890abcdefgHIJKLMNOPQRSTuvwxYZ

# z.ai API (Anthropic Compatible with Bearer Auth)
# z.ai uses Anthropic-compatible API format at /api/anthropic/v1/messages
# ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/anthropic

# ── OpenTelemetry Distributed Tracing ─────────────────────────────────────────
# OTLP collector endpoint (e.g., http://localhost:4317 for Jaeger/Tempo)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Sampling rate (0.0 to 1.0, default: 0.1 for 10%)
# OTEL_TRACES_SAMPLER_ARG=0.1
# Service name for tracing (default: burncloud)
# OTEL_SERVICE_NAME=burncloud
