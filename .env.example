# BurnCloud Configuration

# Server
PORT=3000
HOST=127.0.0.1
BASE_URL=http://127.0.0.1:3000

# Test OpenAI API
TEST_OPENAI_BASE_URL=https://api.openai.com
TEST_OPENAI_API_KEY=sk-1231234567890abcdefgHIJKLMNOPQRSTuvwxYZ

# z.ai API (Anthropic Compatible with Bearer Auth)
# z.ai uses Anthropic-compatible API format at /api/anthropic/v1/messages
# ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/anthropic

# Database
# BURNCLOUD_DATABASE_URL=sqlite:///C:/Users/User/AppData/Local/BurnCloud/data.db?mode=rwc

# Encryption
# MASTER_KEY is optional — BurnCloud auto-generates a random 64-char hex key on first launch
# and persists it to $XDG_CONFIG_HOME/burncloud/master.key (mode 0600).
# Uncomment and set only if you need to provide your own key (e.g. syncing across machines).
# WARNING: if you lose the key, all encrypted upstream API keys become permanently unrecoverable.
# MASTER_KEY=your-64-char-hex-key-here

# Logging
RUST_LOG=error
